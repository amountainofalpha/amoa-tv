{
  "manifest_version": 3,
  "name": "AMOA TradingView Overlay",
  "version": "0.1.0",
  "description": "Overlay A Mountain Of Alpha levels on TradingView charts.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "AMOA TV Overlay"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "identity"],
  "host_permissions": [
    "https://amountainofalpha.com/*",
    "https://www.amountainofalpha.com/*",
    "https://www.tradingview.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.tradingview.com/chart/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "world": "ISOLATED"
    },
    {
      "matches": ["https://www.tradingview.com/chart/*"],
      "js": ["page.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]
}
